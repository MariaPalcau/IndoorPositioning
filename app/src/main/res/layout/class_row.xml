<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="5dp"
    app:cardElevation="10dp">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="105dp">

        <TextView
            android:layout_width="200dp"
            android:id="@+id/className"
            android:textSize="16sp"
            android:layout_marginStart="20dp"
            android:text=""
            android:textColor="@color/black"
            android:layout_marginEnd="20dp"
            android:maxLines="1"
            android:textStyle="bold"
            android:layout_marginTop="15dp"
            android:layout_height="wrap_content"/>

        <ImageView
            android:id="@+id/roomPic"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_below="@+id/className"
            android:layout_marginStart="20dp"
            android:layout_marginTop="7dp"
            app:srcCompat="@drawable/room_svgrepo_com"/>

        <TextView
            android:id="@+id/classRoom"
            android:layout_toEndOf="@+id/roomPic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/className"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="20dp"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:text=""
            android:textColor="@color/grey"
            android:textSize="16sp"/>

        <ImageView
            android:id="@+id/clockPic2"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_below="@+id/classRoom"
            android:layout_marginStart="20dp"
            android:layout_marginTop="7dp"
            app:srcCompat="@drawable/clock_svgrepo_com"/>

        <TextView
            android:id="@+id/classTime"
            android:layout_toEndOf="@+id/clockPic2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/classRoom"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="5dp"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:text=""
            android:textColor="@color/grey"
            android:textSize="16sp"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>